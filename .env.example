# Backend API URL
NEXT_PUBLIC_API_URL=http://localhost:3000

# Optional: API timeout in milliseconds (for GET requests)
API_TIMEOUT=10000

# Optional: API POST timeout in milliseconds (for AI processing)
API_POST_TIMEOUT=60000

# Optional: Enable debug logging
DEBUG_API=false

# Google Analytics (optional)
NEXT_PUBLIC_GA_ID=

# Site URL (for production deployment)
NEXT_PUBLIC_SITE_URL=http://localhost:3001
